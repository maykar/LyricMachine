# Required environment variables for LyricMachine
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Spotify API credentials (https://developer.spotify.com/dashboard)
# Without these, Spotify features are disabled but the app still works.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: override the OAuth redirect URI (defaults to http://localhost:5555/api/spotify/callback)
# SPOTIFY_REDIRECT_URI=

# Encryption key for Spotify token storage (64 hex chars / 32 bytes)
# Auto-generated on first Spotify login if not set.
# ENCRYPTION_KEY=

# Required environment variables for LyricMachine
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Spotify API credentials (https://developer.spotify.com/dashboard)
# Without these, Spotify features are disabled but the app still works.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Required for Spotify OAuth: the redirect URI registered in your Spotify app
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5555/api/spotify/callback

# Encryption key for Spotify token storage (64 hex chars / 32 bytes)
# Auto-generated on first Spotify login if not set.
# ⚠️  SENSITIVE — do not commit this value. Losing it invalidates stored tokens.
# ENCRYPTION_KEY=

# API authentication token. Auto-generated on first startup if not set.
# All API requests must include this token in the Authorization header.
# ⚠️  SENSITIVE — do not commit this value.
# API_TOKEN=
